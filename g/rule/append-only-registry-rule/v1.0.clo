  backward_compatibility:
    target: "v1.0 vẫn loadable sau 10 năm"
    method: "Version không bao giờ xóa"
    
  deterministic_behavior:
    target: "Cùng input → cùng output"
    method: "No jitter, no rename, no deletion"
```

